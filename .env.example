# Supabase project settings (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — server-only, NEVER expose to the client/browser.
# Used by API routes (user provisioning) and the seed script.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: password assigned to all seeded demo users (scripts/seed.ts)
SEED_USER_PASSWORD=Password123!
